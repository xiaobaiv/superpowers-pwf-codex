{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"${PLUGIN_ROOT:-$HOME/.codex}\"; \"$ROOT/hooks/run-hook.cmd\" session-start-codex",
            "async": false,
            "statusMessage": "Loading Superpowers workflow rules"
          },
          {
            "type": "command",
            "command": "ROOT=\"${PLUGIN_ROOT:-$HOME/.codex}\"; sh \"$ROOT/hooks/session-start.sh\" 2>/dev/null || true",
            "async": false,
            "statusMessage": "Loading Superpowers task memory"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"${PLUGIN_ROOT:-$HOME/.codex}\"; python3 \"$ROOT/hooks/user_prompt_submit.py\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"${PLUGIN_ROOT:-$HOME/.codex}\"; python3 \"$ROOT/hooks/pre_tool_use.py\" 2>/dev/null || true",
            "statusMessage": "Checking Superpowers roadmap before Bash"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"${PLUGIN_ROOT:-$HOME/.codex}\"; python3 \"$ROOT/hooks/permission_request.py\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"${PLUGIN_ROOT:-$HOME/.codex}\"; python3 \"$ROOT/hooks/post_tool_use.py\" 2>/dev/null || true",
            "statusMessage": "Reviewing Bash against Superpowers task memory"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"${PLUGIN_ROOT:-$HOME/.codex}\"; sh \"$ROOT/hooks/pre-compact.sh\" 2>/dev/null || true",
            "statusMessage": "Preparing Superpowers memory before compact"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "ROOT=\"${PLUGIN_ROOT:-$HOME/.codex}\"; python3 \"$ROOT/hooks/stop.py\" 2>/dev/null || true",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
