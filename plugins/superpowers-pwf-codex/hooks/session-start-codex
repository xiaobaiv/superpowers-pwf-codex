#!/usr/bin/env bash
# Codex SessionStart hook for superpowers plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_superpowers_content=$(cat "${PLUGIN_ROOT}/skills/using-superpowers/SKILL.md" 2>&1 || echo "Error reading using-superpowers skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

integration_note="$(cat <<'EOF'
Superpowers persistent workflow contract:
Superpowers is the only workflow authority.
Use .superpowers/tasks/<task>/task_plan.md as the only implementation roadmap.
Use .superpowers/tasks/<task>/findings.md for requirements, design, research, constraints, root causes, and decisions.
Use .superpowers/tasks/<task>/progress.md for execution history, verification evidence, failures, and next step.
Do not create legacy artifact-type task directories for new work.
Use .superpowers/sdd/progress.md only as the SDD dispatch ledger.
EOF
)"

using_superpowers_escaped=$(escape_for_json "$using_superpowers_content")
integration_note_escaped=$(escape_for_json "$integration_note")
session_context="<EXTREMELY_IMPORTANT>\nYou have superpowers.\n\n**Below is the full content of your 'superpowers:using-superpowers' skill - your introduction to using skills. For all other skills, follow the Codex skill-loading instructions in that skill:**\n\n${using_superpowers_escaped}\n\n**Superpowers persistent workflow note:**\n\n${integration_note_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context" | cat

exit 0
