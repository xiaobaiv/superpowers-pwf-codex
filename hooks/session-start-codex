#!/usr/bin/env bash
# Codex SessionStart hook for superpowers plugin

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

using_superpowers_content=$(cat "${PLUGIN_ROOT}/skills/using-superpowers/SKILL.md" 2>&1 || echo "Error reading using-superpowers skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

integration_note="Persistent memory contract:\nIf a PWF active plan exists, read and respect it before applying any Superpowers workflow.\nFor complex tasks without an active PWF plan, initialize a slug-mode PWF plan first.\nSuperpowers artifacts are formal deliverables; PWF files are the task memory and index.\nSingle-tree default: use PWF slug-mode instead of git worktrees unless the user explicitly asks otherwise."

using_superpowers_escaped=$(escape_for_json "$using_superpowers_content")
integration_note_escaped=$(escape_for_json "$integration_note")
session_context="<EXTREMELY_IMPORTANT>\nYou have superpowers.\n\n**Below is the full content of your 'superpowers:using-superpowers' skill - your introduction to using skills. For all other skills, follow the Codex skill-loading instructions in that skill:**\n\n${using_superpowers_escaped}\n\n**Superpowers + PWF integration note:**\n\n${integration_note_escaped}\n</EXTREMELY_IMPORTANT>"

printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$session_context" | cat

exit 0
